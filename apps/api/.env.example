# 0G Compute Adapter — REQUIRED
# Local: http://localhost:8000 | Deployed: https://your-adapter.railway.app
OG_COMPUTE_URL=http://localhost:8000
OG_API_KEY=sk-0g-your-api-key-here

# Model IDs — must match models available on your 0G adapter
# Mainnet: glm-5-fp8 + deepseek-chat-v3-0324
# Testnet: qwen-2.5-7b-instruct (only chat model available)
OG_PLANNING_MODEL=glm-5-fp8
OG_ACTION_MODEL=deepseek-chat-v3-0324

# Server
PORT=3001

# Agent tuning (optional — defaults shown)
MAX_OUTPUT_TOKENS=2048
WINDOW_LIMIT=40
